# Rendered from deploy/hosts/host.env via deploy/install-app.sh — do not edit .env by hand on VPS.

SECRET_KEY=@SECRET_KEY@
API_KEY=@API_KEY@
DATABASE_URL=sqlite:///./data/orchestrator.db

HOST_PUBLIC_IP=@HOST_PUBLIC_IP@
ORCH_HOST_IP=@ORCH_HOST_IP@

INCUS_SOCKET=/var/lib/incus/unix.socket
INCUS_NETWORK=orch-br0
INCUS_IMAGE=local:gw-golden
INCUS_STORAGE_POOL=default
INCUS_INSTANCE_TYPE=container
INCUS_PROVISIONER=openwrt
INCUS_VM_MEMORY=128MiB
INCUS_VM_CPU=1
INCUS_NET_INTERFACE=eth0

IP_POOL_NETWORK=10.10.0.0/16
IP_POOL_START=10.10.1.10
PORT_POOL_START=@PORT_POOL_START@
PORT_POOL_END=@PORT_POOL_END@
WG_SUBNET_BASE=10.64

HEADSCALE_URL=@HEADSCALE_URL@
# Gateways register via internal bridge (no Cloudflare on this path)
HEADSCALE_GATEWAY_URL=http://@ORCH_HOST_IP@:8080
ORCH_HEADSCALE_CLI=headscale
ORCH_HEADSCALE_CONFIG=/etc/headscale/config.yaml
ORCH_HEADSCALE_USER=gateways
HEADSCALE_PREAUTH_EXPIRATION=876000h

WG_PUBLIC_HOST=@WG_PUBLIC_HOST@
WG_DNS=1.1.1.1
WG_ALLOWED_IPS="0.0.0.0/0, ::/0"
WG_LISTEN_PORT=51820

METRICS_POLL_INTERVAL_SECONDS=30
PROVISIONING_TIMEOUT_SECONDS=600
AGENT_PORT=8081

GATEWAY_AGENT_WHEEL_URL=
