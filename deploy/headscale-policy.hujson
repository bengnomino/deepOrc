{
  "tagOwners": {
    "tag:exit": ["gateways@"],
    "tag:client": ["gateways@"],
    "tag:worker-host": ["workers@"],
    "tag:control-plane": ["control@"]
  },
  "autoApprovers": {
    "exitNode": ["tag:exit"]
  },
  "grants": [
    {
      "src": ["autogroup:member"],
      "dst": ["autogroup:internet"],
      "ip": ["*"]
    },
    {
      "src": ["*"],
      "dst": ["*"],
      "ip": ["*"]
    }
  ]
}
