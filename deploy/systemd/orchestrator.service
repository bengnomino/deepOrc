[Unit]
Description=VDI Exit Node Orchestrator
After=network-online.target headscale.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@APP_DIR@
EnvironmentFile=@APP_DIR@/.env
ExecStart=@APP_DIR@/.venv/bin/uvicorn orchestrator.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
