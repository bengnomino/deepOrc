# Per-worker VPS — copy to deploy/hosts/worker1.env (never commit)
# cp deploy/hosts/worker.env.example deploy/hosts/worker1.env

WORKER_NAME=worker1
WORKER_DISPLAY_NAME="Worker 1"

# Public IP (WireGuard endpoint for gateways on this worker)
HOST_PUBLIC_IP=146.190.232.35

# Control plane Headscale / API
CP_DOMAIN=deeporc.harlock.network
# HEADSCALE_URL=https://deeporc.harlock.network
# CP_API_URL=https://deeporc.harlock.network/orchestrator/api/v1

# Tailscale hostname on the tailnet (MagicDNS: worker1.ts.harlock.network)
TAILSCALE_HOSTNAME=worker1

# Resource pools (per worker — isolated Incus bridge)
# ORCH_HOST_IP=10.10.0.1
# PORT_POOL_START=51001
# PORT_POOL_END=52000
# IP_POOL_NETWORK=10.10.0.0/16
# IP_POOL_START=10.10.1.10

# Set after register-worker-on-cp.sh (or bootstrap writes them)
# WORKER_ID=
# WORKER_TOKEN=

# Worker files are served from the control plane (/packages/worker-bundle.tar.gz).
# APP_DIR=/opt/deeporc-worker
