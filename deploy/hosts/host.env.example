# Per-host config — copy to host.env (never commit host.env)
# cp deploy/hosts/host.env.example deploy/hosts/host.env

# DNS zone apex (Let's Encrypt cert name: BASE_DOMAIN + *.BASE_DOMAIN)
BASE_DOMAIN=harlock.network

# Public HTTPS / Headscale URL subdomain label (FQDN = SERVICE_HOST.BASE_DOMAIN)
SERVICE_HOST=deeporc

# Optional — auto-detected public IP if empty
# HOST_PUBLIC_IP=165.227.156.103

# Optional Cloudflare (DNS A record + Zero Trust Access)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_SKIP_DNS=true
# CLOUDFLARE_ACCESS_EMAIL=you@example.com
# CLOUDFLARE_ACCESS_SKIP=1
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_DNS_PROXIED=true

# Optional — clone repo during bootstrap
# GIT_REPO=https://github.com/bengnomino/deepOrc.git
# GIT_REF=main

# Advanced (defaults shown)
# APP_DIR=/opt/deeporc
# ORCH_HOST_IP=10.10.0.1
# WG_PUBLIC_HOST=
# HEADSCALE_BASE_DOMAIN=ts.harlock.network
# PORT_POOL_START=51001
# PORT_POOL_END=52000
# HEADSCALE_VERSION=0.29.1

# SECRET_KEY and API_KEY are generated on first bootstrap if omitted
