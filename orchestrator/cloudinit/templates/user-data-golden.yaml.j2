#cloud-config
hostname: {{ gateway_name }}

# Golden Alpine image: only per-gateway config + OpenRC start (no apt/pip).
write_files:
  - path: /etc/sysctl.d/99-gateway.conf
    content: |
      net.ipv4.ip_forward = 1
      net.ipv6.conf.all.forwarding = 1

  - path: /etc/wireguard/wg0.conf
    permissions: '0600'
    content: |
      [Interface]
      PrivateKey = {{ wg_private_key }}
      Address = {{ wg_gateway_ip }}/24
      ListenPort = {{ wg_listen_port }}

  - path: /etc/nftables.conf
    content: |
      #!/usr/sbin/nft -f
      flush ruleset

      table inet filter {
        chain input {
          type filter hook input priority filter; policy drop;
          iif "lo" accept
          ct state established,related accept
          iifname "wg0" accept
          udp dport {{ wg_listen_port }} accept
          tcp dport {{ agent_port }} ip saddr { {{ orch_allowed_ip }}, {{ vm_ip }} } accept
        }
        chain forward {
          type filter hook forward priority filter; policy drop;
          iifname "wg0" oifname "{{ net_interface }}" accept
          iifname "{{ net_interface }}" oifname "wg0" ct state established,related accept
        }
      }

      table ip nat {
        chain postrouting {
          type nat hook postrouting priority srcnat; policy accept;
          ip saddr {{ wg_subnet }} oifname "{{ net_interface }}" masquerade
        }
      }

  - path: /etc/init.d/tailscale-up
    permissions: '0755'
    content: |
      #!/sbin/openrc-run
      name="tailscale-up"
      description="Tailscale with Headscale"
      depend() { need tailscaled net; before gateway-routing gateway-agent; }
      start() {
        ebegin "Starting tailscale"
        /usr/local/sbin/tailscale up \
          --login-server={{ headscale_url }} \
          --authkey={{ tailscale_auth_key }} \
          --hostname={{ gateway_name }} \
          --advertise-exit-node \
          --accept-routes
        eend $?
      }
      stop() {
        ebegin "Stopping tailscale"
        /usr/local/sbin/tailscale down
        eend $?
      }

  - path: /etc/init.d/gateway-routing
    permissions: '0755'
    content: |
      #!/sbin/openrc-run
      name="gateway-routing"
      description="WireGuard reply routing"
      depend() { need net wg-quick.wg0; before gateway-agent; }
      start() {
        ebegin "Gateway routing rules"
        ip rule del pref 35 to {{ wg_subnet }} lookup main 2>/dev/null || true
        ip rule add pref 35 to {{ wg_subnet }} lookup main
        ip rule del pref 40 from {{ wg_gateway_ip }}/32 lookup main 2>/dev/null || true
        ip rule add pref 40 from {{ wg_gateway_ip }}/32 lookup main
        ip rule del pref 50 from {{ vm_ip }}/32 lookup main 2>/dev/null || true
        ip rule add pref 50 from {{ vm_ip }}/32 lookup main
        ip link set wg0 mtu 1280
        eend $?
      }
      stop() {
        ip rule del pref 35 to {{ wg_subnet }} lookup main 2>/dev/null || true
        ip rule del pref 40 from {{ wg_gateway_ip }}/32 lookup main 2>/dev/null || true
        ip rule del pref 50 from {{ vm_ip }}/32 lookup main 2>/dev/null || true
        return 0
      }

  - path: /opt/gateway-agent/config.env
    permissions: '0600'
    content: |
      AGENT_TOKEN={{ agent_token }}
      ORCH_ALLOWED_IP={{ orch_allowed_ip }}
      LISTEN_HOST=0.0.0.0
      LISTEN_PORT={{ agent_port }}

runcmd:
  - sysctl --system
  - rc-update add wg-quick.wg0 default 2>/dev/null || true
  - rc-update add nftables default 2>/dev/null || true
  - rc-update add tailscale-up default 2>/dev/null || true
  - rc-update add gateway-routing default 2>/dev/null || true
  - rc-update add gateway-agent default 2>/dev/null || true
  - rc-service nftables restart
  - rc-service wg-quick.wg0 restart
  - rc-service tailscaled restart
  - rc-service tailscale-up restart
  - rc-service gateway-routing restart
  - rc-service gateway-agent restart
