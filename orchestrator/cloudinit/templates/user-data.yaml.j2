#cloud-config
hostname: {{ gateway_name }}

package_update: true
package_upgrade: false

packages:
  - wireguard
  - nftables
  - curl
  - python3
  - python3-pip
  - python3-venv

write_files:
  - path: /etc/sysctl.d/99-gateway.conf
    content: |
      net.ipv4.ip_forward = 1
      net.ipv6.conf.all.forwarding = 1

  - path: /etc/wireguard/wg0.conf
    permissions: '0600'
    content: |
      [Interface]
      PrivateKey = {{ wg_private_key }}
      Address = {{ wg_gateway_ip }}/24
      ListenPort = {{ wg_listen_port }}

  - path: /etc/nftables.conf
    content: |
      #!/usr/sbin/nft -f
      flush ruleset

      table inet filter {
        chain input {
          type filter hook input priority filter; policy drop;
          iif "lo" accept
          ct state established,related accept
          iifname "wg0" accept
          udp dport {{ wg_listen_port }} accept
          tcp dport {{ agent_port }} ip saddr { {{ orch_allowed_ip }}, {{ vm_ip }} } accept
        }
        chain forward {
          type filter hook forward priority filter; policy drop;
          iifname "wg0" oifname "enp5s0" accept
          iifname "enp5s0" oifname "wg0" ct state established,related accept
        }
      }

      table ip nat {
        chain postrouting {
          type nat hook postrouting priority srcnat; policy accept;
          ip saddr {{ wg_subnet }} oifname "enp5s0" masquerade
        }
      }

  - path: /etc/systemd/system/tailscale-up.service
    content: |
      [Unit]
      Description=Tailscale up with exit node
      After=network-online.target
      Wants=network-online.target

      [Service]
      Type=oneshot
      RemainAfterExit=yes
      ExecStart=/usr/bin/tailscale up \
        --login-server={{ headscale_url }} \
        --authkey={{ tailscale_auth_key }} \
        --hostname={{ gateway_name }} \
        --advertise-exit-node \
        --accept-routes
      ExecStop=/usr/bin/tailscale down

      [Install]
      WantedBy=multi-user.target

  - path: /etc/systemd/system/gateway-routing.service
    content: |
      [Unit]
      Description=WireGuard reply routing (keep UDP on VPS IP)
      After=network-online.target wg-quick@wg0.service
      Requires=wg-quick@wg0.service

      [Service]
      Type=oneshot
      RemainAfterExit=yes
      ExecStart=/bin/sh -c 'ip rule del pref 35 to {{ wg_subnet }} lookup main 2>/dev/null || true; ip rule add pref 35 to {{ wg_subnet }} lookup main; ip rule del pref 40 from {{ wg_gateway_ip }}/32 lookup main 2>/dev/null || true; ip rule add pref 40 from {{ wg_gateway_ip }}/32 lookup main; ip rule del pref 50 from {{ vm_ip }}/32 lookup main 2>/dev/null || true; ip rule add pref 50 from {{ vm_ip }}/32 lookup main; ip link set wg0 mtu 1280'
      ExecStop=/bin/sh -c 'ip rule del pref 35 to {{ wg_subnet }} lookup main 2>/dev/null || true; ip rule del pref 40 from {{ wg_gateway_ip }}/32 lookup main 2>/dev/null || true; ip rule del pref 50 from {{ vm_ip }}/32 lookup main 2>/dev/null || true'

      [Install]
      WantedBy=multi-user.target

  - path: /opt/gateway-agent/config.env
    permissions: '0600'
    content: |
      AGENT_TOKEN={{ agent_token }}
      ORCH_ALLOWED_IP={{ orch_allowed_ip }}
      LISTEN_HOST=0.0.0.0
      LISTEN_PORT={{ agent_port }}

  - path: /etc/systemd/system/gateway-agent.service
    content: |
      [Unit]
      Description=Gateway Agent API
      After=wg-quick@wg0.service network-online.target
      Wants=network-online.target

      [Service]
      EnvironmentFile=/opt/gateway-agent/config.env
      WorkingDirectory=/opt/gateway-agent
      ExecStart=/opt/gateway-agent/venv/bin/uvicorn gateway_agent.main:app --host 0.0.0.0 --port {{ agent_port }}
      Restart=on-failure
      RestartSec=5

      [Install]
      WantedBy=multi-user.target

runcmd:
  - sysctl --system
  - curl -fsSL https://tailscale.com/install.sh | sh
  - python3 -m venv /opt/gateway-agent/venv
  - /opt/gateway-agent/venv/bin/pip install --upgrade pip fastapi uvicorn pydantic-settings
{% if gateway_agent_wheel_url %}
  - /opt/gateway-agent/venv/bin/pip install {{ gateway_agent_wheel_url }}
{% else %}
  - mkdir -p /opt/gateway-agent/src
{% endif %}
  - systemctl enable --now nftables
  - systemctl enable --now wg-quick@wg0
  - systemctl enable --now tailscale-up
  - systemctl enable --now gateway-routing
  - systemctl enable --now gateway-agent
